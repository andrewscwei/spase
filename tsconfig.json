{
  "compilerOptions": {
    "lib": [
      "DOM",
      "ESNext"
    ],
    "module": "esnext",
    "noImplicitAny": true,
    "rootDir": "src",
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "target": "esnext",
    "types": [
      "vitest/globals"
    ]
  },
  "include": [
    "src"
  ]
}
